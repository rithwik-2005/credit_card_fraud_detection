# Local development environment variables
# Copy this file to .env and fill in the real values.

# MLflow tracking settings for local model registry / experiment tracking
MLFLOW_TRACKING_URI=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# Flask app settings
FASTAPI_URL=http://127.0.0.1:8000/predict
PORT=5000

# Docker Hub / Render deployment values should be configured as secrets
# Do NOT commit real values into GitHub.
DOCKERHUB_USERNAME=
DOCKERHUB_PASSWORD=
RENDER_API_KEY=
RENDER_SERVICE_ID=
